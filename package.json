{
  "name": "organator",
  "version": "1.0.0",
  "description": "O Control Plane Open-Source para fundadores de SaaS. Automatize o onboarding e o provisionamento de infraestrutura (AWS/Vercel/Docker) para clientes Enterprise.",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@babel/types": "^7.29.7",
    "es-abstract": "^1.24.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "zod": "^4.4.3"
  }
}
