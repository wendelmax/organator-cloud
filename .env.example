# ==========================================
# Configurações do Organator Cloud (Monorepo)
# ==========================================

# 1. Banco de Dados (PostgreSQL)
# Usado pelo Prisma em 'packages/core-models' e pelo 'control-plane-api'
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/organator_db?schema=public"

# 2. Filas e Mensageria (Redis + BullMQ)
# Usado pelo 'control-plane-api' (producer) e 'provisioner-worker' (consumer)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# 3. Autenticação JWT (Backend)
# Chave secreta usada pelo NestJS para assinar os tokens dos usuários
JWT_SECRET="super_secret_jwt_key_change_in_production"

# 4. NextAuth (Frontend)
# URL base do painel administrativo
NEXTAUTH_URL="http://localhost:3000"
# Gerado via: openssl rand -base64 32
NEXTAUTH_SECRET="super_secret_nextauth_key_change_in_production"

# 5. URLs das APIs (Frontend Next.js)
# URL onde o Control Plane API (NestJS) está rodando
NEXT_PUBLIC_API_URL="http://localhost:3001/v1"

# 6. Integração Stripe (Pagamentos e Onboarding)
# Substitua com suas chaves de teste (Modo Teste) geradas no Dashboard da Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
